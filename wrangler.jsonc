{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "edtpages",
  "compatibility_date": "2026-03-09",

  "assets": {
    "directory": ".",
    "exclude": [
      ".git/*",
      ".wrangler/*",
      "README.md"
    ]
  },

  "workers_dev": false,
  "preview_urls": false,

  "custom_domains": [
    "insects.qzz.io"
  ]
}
